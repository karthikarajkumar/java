6)Write a program to find the largest word in a given string
Input:  "I love programming in java"
o/p: programming

import java.util.Scanner;
public class Main{
    public static void main(String args[]){
        Scanner scan=new Scanner(System.in);
        String str=scan.nextLine();
        
        String word="";
        String maxword="";
        
        for(int i=0;i<str.length();i++){
            char ch=str.charAt(i);
            if(ch != ' '){
                word=word+ch;            
            }
            else{
                if(word.length()>maxword.length()){
                    maxword=word;
                }
                word="";
            }
        }
        
        if(word.length()>maxword.length()){
                    maxword=word;
        }
        
        System.out.println(maxword);
    }
}

7)Count number of words in a given string
Input:  "I love java programming"
o/p: 4

import java.util.Scanner;

public class Main {
    public static void main(String[] args) {

        Scanner scan = new Scanner(System.in);
        String str = scan.nextLine();

        int count = 0;

        for (int i = 0; i < str.length(); i++) {
            if (str.charAt(i) == ' ') {
                count++;
            }
        }

        // words = spaces + 1
        if (str.length() > 0) {
            count = count + 1;
        }

        System.out.println("Number of words: " + count);

        scan.close();
    }
}

8)Change case of each character in a string
i/p: HeLLo123
o/p: hEllO123

import java.util.Scanner;

public class Main {
    public static void main(String[] args) {

        Scanner scan = new Scanner(System.in);
        String str = scan.nextLine();

        String result = "";

        for (int i = 0; i < str.length(); i++) {
            char ch = str.charAt(i);

            // lowercase → uppercase
            if (ch >= 'a' && ch <= 'z') {
                result = result + (char)(ch - 32);
            }
            // uppercase → lowercase
            else if (ch >= 'A' && ch <= 'Z') {
                result = result + (char)(ch + 32);
            }
            else {
                result = result + ch;  // keep other characters same
            }
        }

        System.out.println(result);

        scan.close();
    }
}

9)Reverse words in a string
i/p: I love java
o/p: java love I

import java.util.Scanner;

public class Main {
    public static void main(String[] args) {

        Scanner scan = new Scanner(System.in);
        String str = scan.nextLine();

        String word = "";

        for (int i = str.length() - 1; i >= 0; i--) {

            char ch = str.charAt(i);

            if (ch != ' ') {
                word = ch + word;   // build word
            } else {
                System.out.print(word + " ");
                word = "";
            }
        }

        // print last word
        System.out.print(word);

        scan.close();
    }
}
