4)remove duplicates in array

import java.util.Scanner;

public class problems{

	public static void main(String args[]) {
		
		Scanner scan=new Scanner(System.in);
		int n=scan.nextInt();
		if(n==0){
		    System.out.println("no elements");
		}
		int [] arr=new int[n];
		for(int i=0;i<n;i++) {
			arr[i]=scan.nextInt();
		}
		for(int i=0;i<n-1;i++) {           //array sorting
			for(int j=0;j<n-i-1;j++) {
				if(arr[j]>arr[j+1]) {
					int t=arr[j];
					arr[j]=arr[j+1];
					arr[j+1]=t;		
				}
			}
		}
		
		for(int i=0;i<n;i++) {
			System.out.print(arr[i] + " ");
		}
		
	   int j=0;
		for(int i=1;i<n;i++) {
			if(arr[i]!=arr[j]) {
				j++;
				arr[j]=arr[i];
			}
		}
		int newsize=j+1;
		for(int i=0;i<newsize;i++) {
			System.out.print(arr[i] + " ");
		}
		
	}
}

5)Find two numbers in an array whose sum = target.

Example
Array: [2, 7, 11, 15]
Target = 9
Output: Pair: (2, 7)

import java.util.Scanner;
public class Main{
    public static void main(String args[]){
        Scanner scan=new Scanner(System.in);
        int n=scan.nextInt();
        int [] arr=new int[n];
        for(int i=0;i<n;i++){
            arr[i]=scan.nextInt();
        }
        int target=scan.nextInt();
        
        boolean found=false;
        for(int i=0;i<n;i++){
            for(int j=i+1;j<n;j++){
                if(arr[i]+arr[j]==target){
                    System.out.println("(" + arr[i] + "," + arr[j] + ")");
                    found=true;
                }
    
            }
        }
        
        if(!found){
            System.out.println("no pair found");
        }
        scan.close();
     }
}

6)merge two sorted arrays
input
4
1 3 5 7
4
2 4 6 8
Output
1 2 3 4 5 6 7 8

import java.util.Scanner;
public class Main{
    public static void main(String args[]){
        Scanner scan=new Scanner(System.in);
        int n=scan.nextInt();
        int [] arr=new int[n];
        for(int i=0;i<n;i++){
            arr[i]=scan.nextInt();
        }
        
        int m=scan.nextInt();
        int [] arr1=new int[m];
        for(int i=0;i<m;i++){
            arr1[i]=scan.nextInt();
        }
        
        int i=0,j=0;
        while(i<n && j<m){
            if(arr[i]<arr1[j]){
                System.out.print(arr[i] + " ");
                i++;
            }
            else{
                System.out.print(arr1[j] + " ");
                j++;
            }
        }
        
        while(i<n){
            System.out.print(arr[i] + " ");
            i++;
        }
        while(j<m){
            System.out.print(arr1[j] + " ");
            j++;
        }
        
    }
}

