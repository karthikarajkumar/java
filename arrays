1)Count frequency of each element in an array

package practice_java;

import java.util.Scanner;

public class problems{
	
	static int max(int arr[],int n) {    //func to return max element
		int maxi=arr[0];
		for(int i=0;i<n;i++) {
			if (arr[i]>maxi) {
				maxi=arr[i];
			}
		}
		return maxi;
	}
	public static void main(String args[]) {     //main func
		
		Scanner scan=new Scanner(System.in);
		int n=scan.nextInt();
		int [] arr=new int[n];
		for(int i=0;i<n;i++) {
			arr[i]=scan.nextInt();
		}
		
		int m=max(arr,n);
		
		int [] fre=new int[m+1];     //array declaration
		for(int i=0;i<m+1;i++) {     //intialize all elements to 0 in frequency array
			fre[i]=0;
		}
		for(int i=0;i<n;i++) {      //traverse i/p array and increment elements of fre array
			fre[arr[i]]++;
		}
		for(int i=0;i<m+1;i++) {
			if (fre[i]!=0) {
				System.out.println(i + ":" + fre[i]);
			}
		}
	}
}

