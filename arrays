public class Main {
    public static void main(String[] args) {

        Scanner scan = new Scanner(System.in);
        int n = scan.nextInt();
        int[] arr1 = new int[n];
        for (int i = 0; i < n; i++) {
            arr1[i] = scan.nextInt();
        }

        boolean found=false;
        for (int i = 0; i < n; i++) {
            for (int j =i+1;j<n;j++) {
                if (arr1[i] == arr1[j]) {
