public class Main{
	
	static int max(int arr[],int n) {    //func to return max element
		int maxi=arr[0];
		for(int i=0;i<n;i++) {
			if (arr[i]>maxi) {
				maxi=arr[i];
			}
		}
		return maxi;
	}
	public static void main(String args[]) {     //main func
		
		Scanner scan=new Scanner(System.in);
		int n=scan.nextInt();
		int [] arr=new int[n];
		for(int i=0;i<n;i++) {
			arr[i]=scan.nextInt();
		}
		
