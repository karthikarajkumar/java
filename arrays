		            }
		        }
		    }
		}
		
	}
}

10)find equilibrium index of an array
i/p
arr = [1, 3, 5, 2, 2]
o/p
index = 2

Left side  → 1 + 3 = 4  
Right side → 2 + 2 = 4 

import java.util.Scanner;

public class Main{
	
	public static void main(String args[]) {     
		
		Scanner scan=new Scanner(System.in);
		int n=scan.nextInt();
		int [] arr=new int[n];
		for(int i=0;i<n;i++) {
			arr[i]=scan.nextInt();
		}
		
		int total=0;
		for(int i=0;i<n;i++){  //find total sum
		    total+=arr[i];
		}
		
		int leftsum=0;
		for(int i=0;i<n;i++){
		    total-=arr[i];      //total act as rightsum
		    if(leftsum==total){
		        System.out.print(i);
		    }
		    leftsum+=arr[i];
		}
		
	}
}

11)Check if Array is a subset of another array or not
i/p
5
1 2 3 4 5
2
2 4
o/p
subset

import java.util.Scanner;

public class Main{
	
	public static void main(String args[]) {     
		
		Scanner scan=new Scanner(System.in);
		int n=scan.nextInt();
		int [] arr1=new int[n];
		for(int i=0;i<n;i++) {
			arr1[i]=scan.nextInt();
		}
		
		int m=scan.nextInt();
		int [] arr2=new int[m];
		for(int i=0;i<m;i++) {
			arr2[i]=scan.nextInt();
		}
		
		boolean issubset=true;
		boolean found=false;
		
		for(int i=0;i<m;i++){
		    for(int j=0;j<n;j++){
		        if(arr2[i]==arr1[j]){
		            found=true;
		            break;
		        }
		    }
		    
		    if(!found){
		    issubset=false;
		    break;
		    }
		}
		
		if(issubset){
		    System.out.print("subset");
		}
		else{
		    System.out.print("not subset");
		}
	}
}
