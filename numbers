5) fibonacci series

i)without recursive function

import java.util.Scanner;

public class problems {
	
	static void fib(int n) {
		int a=0,b=1;
		int sum=0;
		
		if(n>=1) {
		  System.out.print(a + " ");
		}
		
		if(n>=2) {
		  System.out.print(b + " ");
		}
		for(int i=2;i<n;i++) {
			sum=a+b;
			System.out.print(sum + " ");
			a=b;
			b=sum;
		}
	}
        public static void main(String args[]) {
		
		Scanner scan=new Scanner(System.in);
		int n=scan.nextInt();
		
		fib(n);
	}
}

ii)with recursive function

import java.util.Scanner;

public class problems {
	
	static int fib(int n) {
		if(n==0 || n==1) {
			return n;
		}
		
		else {
			return fib(n-1)+fib(n-2);
		}
	}
        public static void main(String args[]) {
		
		Scanner scan=new Scanner(System.in);
		int n=scan.nextInt();
		
		for(int i=0;i<n;i++) {
			System.out.print(fib(i) + " ");
		}
	}
}

